# Lighter API配置
LIGHTER_API_KEY=your_api_key_here
LIGHTER_API_SECRET=your_api_secret_here
LIGHTER_PRIVATE_KEY=your_private_key_here

# 网络配置
LIGHTER_NETWORK=testnet  # mainnet 或 testnet
LIGHTER_API_URL=https://api.lighter.xyz
LIGHTER_WS_URL=wss://ws.lighter.xyz

# 交易配置
MAX_POSITION_SIZE=10000  # 最大仓位大小
MAX_ORDER_SIZE=1000      # 最大单笔订单大小
DEFAULT_LEVERAGE=10      # 默认杠杆

# 风险管理
STOP_LOSS_PERCENTAGE=5   # 止损百分比
TAKE_PROFIT_PERCENTAGE=10 # 止盈百分比
MAX_DRAWDOWN=20          # 最大回撤百分比

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=lighter_trading.log